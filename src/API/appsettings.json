{
  "ConnectionStrings": {
    "SqliteConnection": "Data Source=api.db"
  },
  "Auditoria": {
    "Habilitado": true,
    "RegistrarHistoricoDetalhado": false
  },
  "Outbox": {
    "Habilitado": false,
    "IntervaloEmSegundos": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
